<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="debugger_gdbmi wx3.2.x (64 bit)Nly" />
		<Option compiler="gnu_gcc_compiler_cbnightly" />
		<Build>
			<Target title="default">
				<Option output="$(#cb)/devel32_64/share/CodeBlocks/plugins/debugger_gdbmi" prefix_auto="1" extension_auto="1" />
				<Option object_output="$(#cb)/.obj32_64/plugins/contrib/debugger_gdbmi" />
				<Option type="3" />
				<Option compiler="gnu_gcc_compiler_cbnightly" />
				<Option parameters="--debug-log --no-dde --no-check-associations --multiple-instance  --verbose --no-splash-screen  /p debug" />
				<Option host_application="$(#cb)/devel32_64/codeblocks.exe" />
				<Option run_host_application_in_terminal="0" />
				<Compiler>
					<Add option="-Wextra" />
					<Add option="-Wall" />
					<Add option="-std=gnu++11" />
					<Add option="-g" />
				</Compiler>
				<ExtraCommands>
					<Add after="cmd /c if not exist .\bin mkdir .\bin" />
					<Add after="cmd /c zip -j9 $(#cb)/devel32_64/share/codeblocks/debugger_gdbmi.zip src/resources\manifest.xml" />
					<Add after="cmd /c zip -j9 ./bin/debugger_gdbmi.cbplugin $(#cb)/devel32_64/share/codeblocks/debugger_gdbmi.zip" />
					<Add after="cmd /c zip -j9 ./bin/debugger_gdbmi.cbplugin $(#cb)\devel32_64\share\codeblocks\plugins\debugger_gdbmi.dll" />
					<Mode after="always" />
				</ExtraCommands>
			</Target>
			<Environment>
				<Variable name="CB_TRUNK" value="$(#cb)..\..\" />
				<Variable name="WX_CFG" value="" />
				<Variable name="WX_SUFFIX" value="u" />
				<Variable name="WX_VERSION" value="32" />
			</Environment>
		</Build>
		<VirtualTargets>
			<Add alias="All" targets="default;" />
		</VirtualTargets>
		<Compiler>
			<Add option="-Wextra" />
			<Add option="-Wall" />
			<Add option="-std=gnu++11" />
			<Add option="-m64" />
			<Add option="-g" />
			<Add option="$(#CB_RELEASE_TYPE)" />
			<Add option="-pipe" />
			<Add option="-mthreads" />
			<Add option="-fmessage-length=0" />
			<Add option="-fexceptions" />
			<Add option="-DHAVE_W32API_H" />
			<Add option="-DBUILDING_PLUGIN" />
			<Add option="-D__WXMSW__" />
			<Add option="-DWXUSINGDLL" />
			<Add option="-DNOPCH" />
			<Add option="-DwxUSE_UNICODE" />
			<Add option="-D_WIN64" />
			<Add option="-DCC_NO_COLLAPSE_ITEM" />
			<Add option="-DcbDEBUG" />
			<Add option="-DDOLOGSNIP" />
			<Add directory="$(#cb)/include" />
			<Add directory="$(#cb)/sdk/wxscintilla/include" />
			<Add directory="$(#cb)/include/tinyxml" />
			<Add directory="src" />
			<Add directory="src/LSPclient" />
			<Add directory="src/winprocess" />
			<Add directory="src/winprocess/asyncprocess" />
			<Add directory="src/winprocess/misc" />
			<Add directory="$(#WX32_64.include)" />
			<Add directory="$(#WX32_64.lib)/gcc_dll$(WX_CFG)/msw$(WX_SUFFIX)" />
		</Compiler>
		<ResourceCompiler>
			<Add directory="$(#WX32_64.include)" />
			<Add directory="$(#WX32_64)/lib/gcc_dll$(WX_CFG)/msw$(WX_SUFFIX)" />
		</ResourceCompiler>
		<Linker>
			<Add option="-m64" />
			<Add option="-mthreads" />
			<Add option="-Wl,--enable-auto-image-base" />
			<Add option="-Wl,--add-stdcall-alias" />
			<Add option="-Wl,--enable-auto-import" />
			<Add option="-Wl,--no-undefined" />
			<Add library="codeblocks" />
			<Add library="wxmsw$(WX_VERSION)$(WX_SUFFIX)" />
			<Add directory="$(#cb)/devel32_64" />
			<Add directory="$(#WX32_64.lib)/gcc_dll$(WX_CFG)" />
		</Linker>
		<Unit filename="src/actions.cpp" />
		<Unit filename="src/actions.h" />
		<Unit filename="src/cJSON.cpp" />
		<Unit filename="src/cJSON.h" />
		<Unit filename="src/cmd_queue.cpp" />
		<Unit filename="src/cmd_queue.h" />
		<Unit filename="src/cmd_result_parser.cpp" />
		<Unit filename="src/cmd_result_parser.h" />
		<Unit filename="src/cmd_result_tokens.cpp" />
		<Unit filename="src/cmd_result_tokens.h" />
		<Unit filename="src/config.cpp">
			<Option target="&lt;{~None~}&gt;" />
		</Unit>
		<Unit filename="src/config.h">
			<Option target="&lt;{~None~}&gt;" />
		</Unit>
		<Unit filename="src/databreakpointdlg.cpp" />
		<Unit filename="src/databreakpointdlg.h" />
		<Unit filename="src/dbgGDBmi.cpp" />
		<Unit filename="src/dbgGDBmi.h" />
		<Unit filename="src/debuggeroptionsdlg.cpp" />
		<Unit filename="src/debuggeroptionsdlg.h" />
		<Unit filename="src/debuggeroptionsprjdlg.cpp" />
		<Unit filename="src/debuggeroptionsprjdlg.h" />
		<Unit filename="src/definitions.cpp" />
		<Unit filename="src/definitions.h" />
		<Unit filename="src/editbreakpointdlg.cpp" />
		<Unit filename="src/editbreakpointdlg.h" />
		<Unit filename="src/editwatchdlg.cpp" />
		<Unit filename="src/editwatchdlg.h" />
		<Unit filename="src/escape.cpp" />
		<Unit filename="src/escape.h" />
		<Unit filename="src/events.cpp" />
		<Unit filename="src/events.h" />
		<Unit filename="src/frame.cpp" />
		<Unit filename="src/frame.h" />
		<Unit filename="src/gdb_executor.cpp" />
		<Unit filename="src/gdb_executor.h" />
		<Unit filename="src/helpers.cpp" />
		<Unit filename="src/helpers.h" />
		<Unit filename="src/json_node.cpp" />
		<Unit filename="src/json_node.h" />
		<Unit filename="src/macros.h" />
		<Unit filename="src/remotedebugging.h" />
		<Unit filename="src/resources/GDBMiManifest.xml" />
		<Unit filename="src/updated_variable.cpp" />
		<Unit filename="src/updated_variable.h" />
		<Extensions/>
	</Project>
</CodeBlocks_project_file>
